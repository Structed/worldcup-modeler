<div class="header-inner">
    <a class="brand" href="">
        <span class="brand-trophy" aria-hidden="true">🏆</span>
        <span class="brand-text">
            <span class="brand-title">World Cup <span class="brand-year">2026</span></span>
            <span class="brand-sub">Modeler</span>
        </span>
    </a>

    <button title="Navigation menu" class="nav-toggler" @onclick="ToggleNavMenu" aria-label="Toggle navigation">
        <span class="nav-toggler-bar"></span>
        <span class="nav-toggler-bar"></span>
        <span class="nav-toggler-bar"></span>
    </button>

    <nav class="@NavMenuCssClass main-nav" @onclick="CollapseNavMenu">
        <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
            <span class="bi bi-house-door-fill-nav-menu" aria-hidden="true"></span> Home
        </NavLink>
        <NavLink class="nav-link" href="groups">
            <span class="bi bi-list-nested-nav-menu" aria-hidden="true"></span> Group Stage
        </NavLink>
        <NavLink class="nav-link" href="bracket">
            <span class="bi bi-plus-square-fill-nav-menu" aria-hidden="true"></span> Knockout Bracket
        </NavLink>
        <NavLink class="nav-link" href="about">
            <span class="bi bi-info-circle-fill-nav-menu" aria-hidden="true"></span> About
        </NavLink>
    </nav>
</div>

@code {
    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void CollapseNavMenu()
    {
        collapseNavMenu = true;
    }
}
