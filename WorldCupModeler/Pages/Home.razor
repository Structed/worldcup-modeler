@page "/"
@inherits TournamentPage

<PageTitle>World Cup 2026 Modeler</PageTitle>

<div class="page-header">
    <h1>🏆 World Cup 2026 Modeler</h1>
    <p class="lead">Model the FIFA World Cup 2026. Pick who advances, optionally add scores, and watch the bracket fill in. Everything is saved in your browser.</p>
</div>

@{
    var champion = Tournament.Champion;
}
@if (champion is not null)
{
    <div class="champion-banner">
        <div class="champion-label">Your champion</div>
        <div class="champion-team"><Flag Code="@champion.Code" /> @champion.Name</div>
    </div>
}

<div class="home-cards">
    <a class="home-card" href="groups">
        <h2>① Group Stage</h2>
        <p>12 groups of 4. Enter scores to auto-rank each group, or reorder teams to override who advances.</p>
        <span class="home-progress">@CompletedGroups / 12 groups complete</span>
    </a>
    <a class="home-card" href="bracket">
        <h2>② Knockout Bracket</h2>
        <p>Round of 32 through the Final. Click the team you think advances; scores are optional.</p>
        <span class="home-progress">@DecidedKnockout / 32 matches decided</span>
    </a>
</div>

<div class="home-actions">
    <button class="btn btn-outline-danger" @onclick="Reset">Reset everything</button>
</div>

<p class="footnote">
    Note: the eight best third-placed teams are assigned to Round-of-32 slots using a
    deterministic rule that avoids same-group rematches — a simplification of FIFA's full
    Annex C lookup table. Group tiebreakers use points, then goal difference, then goals for.
</p>

@code {
    private int CompletedGroups => Tournament.Groups.Count(Tournament.IsGroupComplete);

    private int DecidedKnockout => Tournament.GetKnockoutMatches().Count(m => m.Winner is not null);

    private async Task Reset() => await Tournament.ResetAllAsync();
}
